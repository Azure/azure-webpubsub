# ---- Azure Web PubSub ----
# The control plane is the ONLY component that holds Web PubSub credentials.
# It mints short-lived client access tokens for connectors and browser clients.

# Endpoint form (used with AAD — the default, per least-privilege / passwordless guidance).
# Find it in the Azure portal: your Web PubSub resource -> "URL" (https://<name>.webpubsub.azure.com).
WEBPUBSUB_ENDPOINT=https://<your-web-pubsub>.webpubsub.azure.com

# Auth mode: "aad" (default, recommended) or "key".
# AAD uses DefaultAzureCredential (az login / azd auth login locally). The signed-in
# identity needs the "Web PubSub Service Owner" role on the resource to mint tokens.
WEBPUBSUB_AUTH_MODE=aad

# Only used when WEBPUBSUB_AUTH_MODE=key. Leave blank when using AAD.
# Portal: Web PubSub resource -> "Keys" -> Connection string.
WEBPUBSUB_CONNECTION_STRING=

# Hub name (any identifier; connectors, clients and control plane must agree).
WEBPUBSUB_HUB=agentrelay

# ---- Control plane ----
CONTROL_PLANE_PORT=8080
CONTROL_PLANE_URL=http://localhost:8080

# ---- Foundry connector (only needed for `npm run connector:foundry`) ----
# Project endpoint from `azd env get-values` (AZURE_AI_PROJECT_ENDPOINT) after you
# deploy the hosted agent (see foundry-agent/README.md).
FOUNDRY_PROJECT_ENDPOINT=
# The deployed hosted agent's name.
FOUNDRY_AGENT_NAME=
# AAD scope for the Foundry data plane. Default works for most projects; override if needed.
FOUNDRY_AAD_SCOPE=https://ai.azure.com/.default
# Foundry data-plane api-version (required query param). Override if your endpoint rejects it.
FOUNDRY_API_VERSION=2025-11-15-preview
# Model arg sent on the Responses call. For a hosted-agent dedicated endpoint this is
# typically ignored (the agent picks the model), but the OpenAI SDK requires a value.
FOUNDRY_MODEL=gpt-4.1-mini
