{
  "name": "agent-relay-foundry",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Demonstrates Azure Web PubSub as a uniform relay for agents across heterogeneous environments, including a hosted Microsoft Foundry agent.",
  "scripts": {
    "control-plane": "tsx src/control-plane/server.ts",
    "connector:mock": "tsx src/connector/main.ts mock",
    "connector:foundry": "tsx src/connector/main.ts foundry",
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck"
  },
  "dependencies": {
    "@azure/identity": "^4.5.0",
    "@azure/web-pubsub": "^1.1.3",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "openai": "^4.104.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.9.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
